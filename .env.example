# ==============================================================================
# Acme App — Latenode White-Label Demo
# ==============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ==============================================================================

# --- Database ---
# SQLite is used by default for local development (no config needed).
# To use PostgreSQL instead, uncomment and set DATABASE_URL:
# DATABASE_URL="postgresql://user:password@localhost:5432/mydb"

# --- App Session ---
# Secret key for encrypting session cookies. Must be at least 32 characters.
# Generate one with: openssl rand -base64 32
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# --- Latenode White-Label ---
# Get these from your Latenode white-label admin panel.
# See: https://documentation.latenode.com/white-label

# RSA private key for signing embedded JWTs (RS512).
# Issued by Latenode support. Both PKCS#1 (BEGIN RSA PRIVATE KEY) and
# PKCS#8 (BEGIN PRIVATE KEY) formats are accepted.
#
# Option A — single line with \n (the app normalizes these automatically):
# LATENODE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----"
#
# Option B — multiline (recommended, easier to paste):
LATENODE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----
YOUR_KEY_HERE
-----END RSA PRIVATE KEY-----"

# Numeric tenant ID provided by Latenode.
LATENODE_TENANT_ID="1"

# Default plan ID assigned to new users on first login.
# Create a plan at White Label → Plans in the admin dashboard.
LATENODE_DEFAULT_PLAN_ID="35"

# --- Optional: Admin API ---
# Required only for the Admin Panel page.
# Create a token at White Label → Access Tokens in the admin dashboard.
LATENODE_API_TOKEN=""

# --- Email Confirmation (Optional) ---
# Set to "true" to require email verification during registration.
# When disabled, users are registered immediately without email check.
EMAIL_CONFIRMATION_ENABLED="false"

# Mailgun credentials (required only when EMAIL_CONFIRMATION_ENABLED=true)
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""
MAILGUN_FROM="noreply@yourdomain.com"
# Use "https://api.eu.mailgun.net" for EU region
MAILGUN_API_URL="https://api.mailgun.net"
